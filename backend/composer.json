{
    "name": "maximiliano/decampoacampo-backend",
    "description": "challenger para posicion en decampoacampo",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Garcia Maximiliano"
        }
    ],
    "require": {
        "php": "^8.5"
    },    
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.7"
    }
}
